[[PH:write a 2-3 line module docstring that says what MiniERP is and what this file does]]"""MiniERP entry point.

MiniERP is a small-business ERP suite: inventory, customers, sales and invoicing,
reporting, and more. This module is the program's entry point. Run it to start the
app; import it to reuse its helpers, which have no side effects on import.
"""[[/PH]]
import sys


def welcome() -> str:
    """Return the line shown when MiniERP starts."""
    return "Welcome to MiniERP"


def python_line() -> str:
    """Return a line that reports the Python version running this program."""
    version = sys.version_info
    return f"Running on Python {version.major}.{version.minor}.{version.micro}"


def describe(value) -> str:
    """Return a short string naming a value's type, for example '42 is a int'."""
    return f"{value!r} is a {type(value).__name__}"


def same_object(a, b) -> bool:
    """Return True only if a and b are the SAME object (identity, not equality)."""
    return a is b


def display_name(name) -> str:
    """Return a usable display name: the trimmed name, or a default if it is missing.

    None and blank or whitespace-only strings all count as missing.
    """
    if name is None:
        return "Guest"
    cleaned = name.strip()
    if cleaned:
        return cleaned
    return "Guest"


def banner(title: str, width: int = 40) -> str:
    """Return a three-line banner: a rule line, the centered title, another rule."""
    rule = "=" * width
    middle = title.center(width)
    return "\n".join([rule, middle, rule])


if __name__ == "__main__":
    print(banner("MiniERP"))
    print(python_line())
