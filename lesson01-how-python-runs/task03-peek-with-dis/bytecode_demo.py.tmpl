"""A sandbox for looking at Python bytecode.

This file is not part of MiniERP yet. It exists so you can watch a tiny function
turn into the instructions the Python virtual machine runs. The function it uses,
line_total, is a preview of the invoice maths you will build for real later.

Run it to see the disassembly:  python bytecode_demo.py
"""
import dis


def line_total(quantity, price):
    """Return the price for a quantity of items: quantity times price."""
    return [[PH:multiply quantity by price]]quantity * price[[/PH]]


if __name__ == "__main__":
    # Show the bytecode the virtual machine will actually execute for line_total.
    dis.dis(line_total)
    # A real result too, so you see the function works and not only how it compiles.
    print("3 x 5 =", line_total(3, 5))
